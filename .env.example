# Pushover Push Notifications
# Sign up at pushover.net → create an app → copy the API Token below.
# Your personal User Key goes in app Settings → Reminders (stored in localStorage, not here).
PUSHOVER_API_TOKEN=your-api-token-here

# Claude AI (NLP Quick Capture — Cmd+K → type a sentence → create task)
# Get your key at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
